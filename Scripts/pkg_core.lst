# --------------------------------------------------- // System // 系统组件
pipewire                                               # audio/video server // 音频/视频服务器
pipewire-alsa                                          # pipewire alsa client // pipewire alsa客户端
pipewire-audio                                         # pipewire audio client // pipewire音频客户端
pipewire-jack                                          # pipewire jack client // pipewire jack客户端
pipewire-pulse                                         # pipewire pulseaudio client // pipewire pulseaudio客户端
gst-plugin-pipewire                                    # pipewire gstreamer client // pipewire gstreamer插件
wireplumber                                            # pipewire session manager // pipewire会话管理器
pavucontrol                                            # pulseaudio volume control // pulseaudio音量控制
pamixer                                                # pulseaudio cli mixer // pulseaudio命令行混音器
networkmanager                                         # network manager // 网络管理器
network-manager-applet                                 # network manager system tray utility // 网络管理器系统托盘工具
bluez                                                  # bluetooth protocol stack // 蓝牙协议栈
bluez-utils                                            # bluetooth utility cli // 蓝牙命令行工具
blueman                                                # bluetooth manager gui // 蓝牙管理器图形界面
brightnessctl                                          # screen brightness control // 屏幕亮度控制
playerctl                                              # media controls // 媒体控制
udiskie                                                # manage removable media // 管理可移动媒体

# --------------------------------------------------- // Display Manager // 显示管理器
sddm                                                   # display manager for KDE plasma // KDE plasma显示管理器
qt5-quickcontrols                                      # for sddm theme ui elements // sddm主题UI元素支持
qt5-quickcontrols2                                     # for sddm theme ui elements // sddm主题UI元素支持
qt5-graphicaleffects                                   # for sddm theme effects // sddm主题效果支持

# --------------------------------------------------- // Window Manager // 窗口管理器
hyprland                                               # wlroots-based wayland compositor // 基于wlroots的wayland合成器
dunst                                                  # notification daemon // 通知守护进程
rofi-wayland                                           # application launcher // 应用程序启动器
waybar                                                 # system bar // 系统状态栏
swww                                                   # wallpaper // 壁纸管理器
hyprlock                                               # lock screen // 锁屏工具
wlogout                                                # logout menu // 注销菜单
grim                                                   # screenshot tool // 截图工具
hyprpicker                                             # color picker // 颜色选择器
slurp                                                  # region select for screenshot/screenshare // 截图/屏幕共享区域选择
satty                                                  # Modern Screenshot Annotation // 现代截图标注工具
cliphist                                               # clipboard manager // 剪贴板管理器
wl-clip-persist                                        # Keep Wayland clipboard even after programs close (avoids crashes) // 保持Wayland剪贴板内容（避免崩溃）
hyprsunset                                             # blue light filter // 蓝光过滤器

