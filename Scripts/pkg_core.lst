xdg-desktop-portal-hyprland                            # xdg desktop portal for hyprland // hyprland的xdg桌面门户
xdg-desktop-portal-gtk                                 # file picker and dbus integration // 文件选择器和dbus集成
xdg-user-dirs                                          # Manage user directories like ~/Desktop and ~/Music // 管理用户目录如~/Desktop和~/Music
pacman-contrib                                         # for system update check // 系统更新检查工具
parallel                                               # for parallel processing // 并行处理工具
jq                                                     # for json processing // JSON处理工具
imagemagick                                            # for image processing // 图像处理工具
qt5-imageformats                                       # for dolphin image thumbnails // dolphin图像缩略图支持
ffmpegthumbs                                           # for dolphin video thumbnails // dolphin视频缩略图支持
kde-cli-tools                                          # for dolphin file type defaults // dolphin文件类型默认设置
libnotify                                              # for notifications // 通知支持
noto-fonts-emoji                                       # emoji font // emoji字体

# --------------------------------------------------- // Theming // 主题相关
